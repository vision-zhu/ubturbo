
cmake_minimum_required(VERSION 3.15)

set(command "/usr/bin/cmake;-DCMAKE_C_FLAGS=;-DCMAKE_C_FLAGS_RELEASE= -fno-omit-frame-pointer -fstack-protector-strong -Wl,-z,noexecstack -Wl,-z,relro -Wl,-z,now -fPIE -fPIC -s -O2 -D_FORTIFY_SOURCE=2 -g -DNDEBUG=1 -lrt -ldl -lm -DENV_HCCS;-DCMAKE_C_FLAGS_DEBUG= -fno-omit-frame-pointer -fstack-protector-strong -Wl,-z,noexecstack -Wl,-z,relro -Wl,-z,now -fPIE -fPIC -s -O0 -ggdb3 -g -lrt -ldl -lm -DDEBUG -DENV_HCCS;-DCMAKE_CXX_FLAGS=;-DCMAKE_CXX_FLAGS_RELEASE= -std=c++17 -fno-omit-frame-pointer -fstack-protector-strong -Wl,-z,noexecstack -Wl,-z,relro -Wl,-z,now -fPIE -fPIC -s -O2 -D_FORTIFY_SOURCE=2 -g -DNDEBUG=1 -lrt -ldl;-DCMAKE_CXX_FLAGS_DEBUG= -std=c++17 -fno-omit-frame-pointer -fstack-protector-strong -Wl,-z,noexecstack -Wl,-z,relro -Wl,-z,now -fPIE -fPIC -s -O0 -ggdb3 -g -lrt -ldl;-DCMAKE_BUILD_TYPE=Release;-DCMAKE_INSTALL_LIBDIR=/root/ubturbo/3rdparty/spdlog-prefix/lib;-DCMAKE_INSTALL_BINDIR=/root/ubturbo/3rdparty/spdlog-prefix/bin;-DCMAKE_INSTALL_PREFIX=/root/ubturbo/3rdparty/spdlog-prefix/;-DBUILD_SHARED_LIBS=OFF;-GUnix Makefiles;-S;/root/ubturbo/3rdparty/spdlog;-B;/root/ubturbo/3rdparty/spdlog-prefix/src/spdlog-build")
set(log_merged "")
set(log_output_on_failure "")
set(stdout_log "/root/ubturbo/3rdparty/spdlog-prefix/src/spdlog-stamp/spdlog-configure-out.log")
set(stderr_log "/root/ubturbo/3rdparty/spdlog-prefix/src/spdlog-stamp/spdlog-configure-err.log")
execute_process(
  COMMAND ${command}
  RESULT_VARIABLE result
  OUTPUT_FILE "${stdout_log}"
  ERROR_FILE "${stderr_log}"
)
macro(read_up_to_max_size log_file output_var)
  file(SIZE ${log_file} determined_size)
  set(max_size 10240)
  if (determined_size GREATER max_size)
    math(EXPR seek_position "${determined_size} - ${max_size}")
    file(READ ${log_file} ${output_var} OFFSET ${seek_position})
    set(${output_var} "...skipping to end...\n${${output_var}}")
  else()
    file(READ ${log_file} ${output_var})
  endif()
endmacro()
if(result)
  set(msg "Command failed: ${result}\n")
  foreach(arg IN LISTS command)
    set(msg "${msg} '${arg}'")
  endforeach()
  if (${log_merged})
    set(msg "${msg}\nSee also\n  ${stderr_log}")
  else()
    set(msg "${msg}\nSee also\n  /root/ubturbo/3rdparty/spdlog-prefix/src/spdlog-stamp/spdlog-configure-*.log")
  endif()
  if (${log_output_on_failure})
    message(SEND_ERROR "${msg}")
    if (${log_merged})
      read_up_to_max_size("${stderr_log}" error_log_contents)
      message(STATUS "Log output is:\n${error_log_contents}")
    else()
      read_up_to_max_size("${stdout_log}" out_log_contents)
      read_up_to_max_size("${stderr_log}" err_log_contents)
      message(STATUS "stdout output is:\n${out_log_contents}")
      message(STATUS "stderr output is:\n${err_log_contents}")
    endif()
    message(FATAL_ERROR "Stopping after outputting logs.")
  else()
    message(FATAL_ERROR "${msg}")
  endif()
else()
  if(NOT "Unix Makefiles" MATCHES "Ninja")
    set(msg "spdlog configure command succeeded.  See also /root/ubturbo/3rdparty/spdlog-prefix/src/spdlog-stamp/spdlog-configure-*.log")
    message(STATUS "${msg}")
  endif()
endif()
